# Copy to .env.local and fill in your values

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://navzz.dev

# ── SMTP for contact form emails (optional) ──
# Recommended: use Resend.com, SendGrid, or Postmark
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# ── Google Search Console ──
# Add your verification token in lib/seo.ts
GOOGLE_SITE_VERIFICATION=your-token-here

# ── Analytics (optional) ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
